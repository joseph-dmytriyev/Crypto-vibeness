# Crypto Vibeness Environment Configuration
# Copy this file to .env and customize as needed

# Server configuration
SERVER_HOST=localhost
SERVER_PORT=9000

# Logging and key storage directories
LOG_DIR=./logs
KEY_DIR=./users

# Cryptography algorithm for asymmetric keys
# Options: "rsa" (default) or "ed25519"
CRYPTO_ALGORITHM=rsa

# Optional: Docker-specific settings
# COMPOSE_PROJECT_NAME=crypto_vibeness
